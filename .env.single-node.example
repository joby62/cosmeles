# Phase-20 / runtime-phase-6 single-node skeleton
DEPLOY_PROFILE=single_node
RUNTIME_ROLE=api
STORAGE_BACKEND=local_fs
SELECTION_RESULT_REPOSITORY_BACKEND=postgres_payload
QUEUE_BACKEND=local
LOCK_BACKEND=local
CACHE_BACKEND=none
REDIS_URL=
LOCK_DOWNGRADE_TO_LOCAL_ON_ERROR=true
CACHE_DOWNGRADE_TO_NONE_ON_ERROR=true
COMPARE_JOB_MAX_CONCURRENCY=1
DATABASE_URL=sqlite:////app/storage/app.db
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=4
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
DB_DOWNGRADE_TO_SQLITE_ON_ERROR=true
DB_DOWNGRADE_SQLITE_URL=sqlite:////app/storage/app.db
ROLLOUT_STEP=worker
ROLLOUT_TARGET_STEP=web
ROLLOUT_ROLLBACK_ENABLED=true
ROLLOUT_CONSISTENCY_ENFORCED=true
API_PUBLIC_ORIGIN=
API_INTERNAL_ORIGIN=http://backend:8000
ASSET_PUBLIC_ORIGIN=
ASSET_OBJECT_KEY_PREFIX=mobile-v2
ASSET_SIGNED_URL_TTL_SECONDS=300
ASSET_SIGNED_URL_ENFORCED=false
ASSET_SIGNING_SECRET=
COOKIE_DOMAIN=
NEXT_PUBLIC_RUNTIME_PROFILE=single_node
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_ASSET_BASE=
BACKEND_HOST=backend
BACKEND_PORT=8000
INTERNAL_API_BASE=http://backend:8000
NEXT_COMPRESS=false
ADMIN_CONSOLE_PASSWORD=
ADMIN_CONSOLE_SESSION_SALT=change-this-cookie-salt
