# Phase-20 / runtime-phase-6 split-runtime skeleton
DEPLOY_PROFILE=split_runtime
RUNTIME_ROLE=api
STORAGE_BACKEND=object_storage_contract
SELECTION_RESULT_REPOSITORY_BACKEND=postgres_payload
QUEUE_BACKEND=local
LOCK_BACKEND=redis_contract
CACHE_BACKEND=redis_contract
REDIS_URL=redis://redis:6379/0
LOCK_DOWNGRADE_TO_LOCAL_ON_ERROR=false
CACHE_DOWNGRADE_TO_NONE_ON_ERROR=false
COMPARE_JOB_MAX_CONCURRENCY=1
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/cosmeles
DB_POOL_SIZE=12
DB_MAX_OVERFLOW=8
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
DB_DOWNGRADE_TO_SQLITE_ON_ERROR=false
DB_DOWNGRADE_SQLITE_URL=sqlite:////app/storage/app.db
ROLLOUT_STEP=worker
ROLLOUT_TARGET_STEP=web
ROLLOUT_ROLLBACK_ENABLED=true
ROLLOUT_CONSISTENCY_ENFORCED=true
API_PUBLIC_ORIGIN=https://api.yuexuan.xyz
API_INTERNAL_ORIGIN=http://api:8000
ASSET_PUBLIC_ORIGIN=https://assets.yuexuan.xyz
ASSET_OBJECT_KEY_PREFIX=mobile-v2
ASSET_SIGNED_URL_TTL_SECONDS=300
ASSET_SIGNED_URL_ENFORCED=true
ASSET_SIGNING_SECRET=change-this-asset-signing-secret
COOKIE_DOMAIN=.yuexuan.xyz
NEXT_PUBLIC_RUNTIME_PROFILE=split_runtime
NEXT_PUBLIC_API_BASE=https://api.yuexuan.xyz
NEXT_PUBLIC_ASSET_BASE=https://assets.yuexuan.xyz
BACKEND_HOST=api
BACKEND_PORT=8000
INTERNAL_API_BASE=http://api:8000
NEXT_COMPRESS=true
